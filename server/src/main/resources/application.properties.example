# server/src/main/resources/application.properties로 복사해서 실제 값을 채워 쓴다.
# application.properties 자체는 비밀키가 들어있어 .gitignore 대상이라 커밋되지 않는다.
# 여기 있는 설정값(ddl-auto, flyway 등)은 비밀이 아니므로 이 파일로 공유한다 —
# 이 값들을 바꿀 땐 실제 application.properties뿐 아니라 이 파일도 같이 갱신할 것.

spring.datasource.url=jdbc:postgresql://localhost:5434/trip
spring.datasource.username=<YOUR_DB_USER>
spring.datasource.password=<YOUR_DB_PASSWORD>
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true

spring.flyway.baseline-on-migrate=true
spring.flyway.baseline-version=1

kakao.api.key=<YOUR_KAKAO_API_KEY>

spring.data.redis.host=localhost
spring.data.redis.port=6379

visitjeju.api.key=<YOUR_VISITJEJU_API_KEY>

gemini.api.key=<YOUR_GEMINI_API_KEY>
spring.ai.google.genai.api-key=${gemini.api.key}
spring.ai.google.genai.chat.model=gemini-2.5-flash
# spring.ai.retry.*는 여기 안 둔다 — google-genai 스타터가 에러를 평범한
# RuntimeException으로 감싸버려서 Spring AI의 RetryTemplate이 재시도 대상으로
# 인식하지 못한다. 재시도는 AiService.chatWithGemini에서 직접 처리한다.

groq.api.key=<YOUR_GROQ_API_KEY>

tourapi.service.key=<YOUR_TOURAPI_SERVICE_KEY>
